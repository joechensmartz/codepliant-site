{
  "name": "codepliant-vscode",
  "displayName": "Codepliant",
  "description": "Scan your codebase and generate compliance documents — Privacy Policy, Terms of Service, AI Disclosure, and more.",
  "version": "0.1.0",
  "publisher": "codepliant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codepliant/codepliant"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "compliance",
    "privacy-policy",
    "terms-of-service",
    "gdpr",
    "ccpa",
    "ai-disclosure",
    "legal"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "workspaceContains:package.json",
    "workspaceContains:.env"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codepliant.scan",
        "title": "Codepliant: Scan Workspace",
        "icon": "$(search)"
      },
      {
        "command": "codepliant.generate",
        "title": "Codepliant: Generate Compliance Documents",
        "icon": "$(file-text)"
      },
      {
        "command": "codepliant.check",
        "title": "Codepliant: Check Compliance Status",
        "icon": "$(checklist)"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "codepliant.scan" },
        { "command": "codepliant.generate" },
        { "command": "codepliant.check" }
      ]
    },
    "configuration": {
      "title": "Codepliant",
      "properties": {
        "codepliant.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan the workspace when it opens."
        },
        "codepliant.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-scan when relevant files (package.json, .env, etc.) are saved."
        },
        "codepliant.outputFormat": {
          "type": "string",
          "default": "markdown",
          "enum": ["markdown", "html"],
          "description": "Output format for generated compliance documents."
        }
      }
    },
    "languages": [
      {
        "id": "codepliant-config",
        "filenames": [".codepliantrc.json", "codepliant.config.json"],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "@vscode/vsce": "^3.0.0"
  },
  "dependencies": {
    "codepliant": "^12.0.0"
  }
}
