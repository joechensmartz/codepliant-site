2:T5cf,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How does Codepliant generate terms of service?","acceptedAnswer":{"@type":"Answer","text":"Codepliant scans your codebase for features like user authentication, payment processing, file uploads, user-generated content, and API integrations. It uses this information to generate terms of service that accurately describe what your application does and the legal terms under which users access it."}},{"@type":"Question","name":"What sections are included in the generated ToS?","acceptedAnswer":{"@type":"Answer","text":"The generated terms of service include: acceptance of terms, description of service, user accounts, prohibited conduct, intellectual property, payment terms (if applicable), limitation of liability, termination, governing law, and dispute resolution. Sections are included or excluded based on what your code actually does."}},{"@type":"Question","name":"Can I customize the generated terms?","acceptedAnswer":{"@type":"Answer","text":"Yes. The generated document is yours to modify. You can add your company name, jurisdiction, specific clauses, and any additional terms. We recommend having a lawyer review the final version."}},{"@type":"Question","name":"Is this free?","acceptedAnswer":{"@type":"Answer","text":"Yes. The CLI is free and open source. Generate terms of service in Markdown at no cost. Pro plan ($29/mo) adds HTML and PDF output with custom branding."}}]}0:{"buildId":"FFULgqaIFg2p08OpDNiks","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Codepliant Terms of Service Generator\",\"applicationCategory\":\"DeveloperApplication\",\"operatingSystem\":\"macOS, Linux, Windows\",\"description\":\"Free terms of service generator that scans your codebase to create accurate, comprehensive ToS documents.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}"}}],["$","article",null,{"className":"py-20 px-6","children":["$","div",null,{"className":"max-w-[680px] mx-auto","children":[["$","p",null,{"className":"text-sm font-medium text-accent mb-4 tracking-wide uppercase","children":"Free Tool"}],["$","h1",null,{"className":"text-4xl font-bold tracking-tight mb-6","children":"Free Terms of Service Generator for Developers"}],["$","p",null,{"className":"text-lg text-muted mb-12","children":"Stop copying generic terms of service templates. Codepliant scans your codebase to understand what your application does — user accounts, payments, file uploads, API access — and generates terms that actually match your product."}],["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Why generate ToS from code?"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"Generic terms of service templates are written for generic applications. They include clauses for features you don't have and miss features you do. If your app handles payments but your ToS doesn't mention refund policies, you have a problem."}],["$","p",null,{"children":"Codepliant detects whether your app has user authentication, payment processing (Stripe, PayPal), file uploads, user-generated content, real-time features, API endpoints, and more. The generated terms of service include relevant sections and omit irrelevant ones."}]]}]]}],"$L3","$L4","$L5"]}]}]],null,"$L6"]}],"loading":null,"isPartial":false}
