2:T62a,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What GDPR documents does Codepliant generate?","acceptedAnswer":{"@type":"Answer","text":"Codepliant generates Privacy Policies, Data Processing Agreements (DPA), Data Subject Access Request (DSAR) Guides, Consent Guides, Data Flow Maps, Data Retention Policies, Privacy Impact Assessments (PIA/DPIA), Sub-Processor Lists, and Compliance Reports — all from scanning your code."}},{"@type":"Question","name":"Does Codepliant replace a Data Protection Officer?","acceptedAnswer":{"@type":"Answer","text":"No. Codepliant is a developer tool that automates the documentation aspect of GDPR compliance. You should still consult with legal professionals and, if required, appoint a DPO. Codepliant helps you create accurate documentation faster."}},{"@type":"Question","name":"How does code scanning help with GDPR?","acceptedAnswer":{"@type":"Answer","text":"GDPR requires you to document what personal data you collect, how you process it, where you store it, and who you share it with. Codepliant scans your ORM schemas, API integrations, analytics SDKs, and auth flows to answer these questions from evidence rather than memory."}},{"@type":"Question","name":"Does Codepliant detect data transfers outside the EU?","acceptedAnswer":{"@type":"Answer","text":"Yes. Codepliant identifies third-party services in your code (AWS, Google Cloud, Stripe, analytics providers) and flags potential international data transfers that require GDPR safeguards like Standard Contractual Clauses."}}]}0:{"buildId":"3_8tk2yXshjsX4BxM6gAi","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Codepliant GDPR Compliance Tool\",\"applicationCategory\":\"DeveloperApplication\",\"operatingSystem\":\"macOS, Linux, Windows\",\"description\":\"GDPR compliance tool that scans your codebase and generates required documentation automatically.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}"}}],["$","article",null,{"className":"py-20 px-6","children":["$","div",null,{"className":"max-w-[680px] mx-auto","children":[["$","p",null,{"className":"text-sm font-medium text-accent mb-4 tracking-wide uppercase","children":"GDPR Compliance"}],["$","h1",null,{"className":"text-4xl font-bold tracking-tight mb-6","children":"GDPR Compliance Tool for Developers"}],["$","p",null,{"className":"text-lg text-muted mb-12","children":"GDPR requires detailed documentation of how your application collects, processes, and stores personal data. Codepliant scans your codebase to generate accurate compliance documents — from privacy policies to data flow maps — in one command."}],["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"GDPR documentation requirements"}],["$","div",null,{"className":"space-y-4","children":[["$","div","Article 13 & 14 — Information to data subjects",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"Article 13 & 14 — Information to data subjects"}],["$","p",null,{"className":"text-sm text-muted","children":"You must inform users about what data you collect, why, and how long you keep it. Codepliant generates this from your database schemas and API integrations."}]]}],"$L3","$L4","$L5"]}]]}],"$L6","$L7","$L8","$L9","$La"]}]}]],null,"$Lb"]}],"loading":null,"isPartial":false}
3:["$","div","Article 28 — Data Processing Agreements",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"Article 28 — Data Processing Agreements"}],["$","p",null,{"className":"text-sm text-muted","children":"If you use third-party processors (cloud providers, analytics, payments), you need DPAs. Codepliant identifies your processors from your code."}]]}]
4:["$","div","Article 30 — Records of processing activities",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"Article 30 — Records of processing activities"}],["$","p",null,{"className":"text-sm text-muted","children":"You must maintain records of all processing activities. Codepliant generates data flow maps and processing records from your codebase."}]]}]
5:["$","div","Article 35 — Data Protection Impact Assessment",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"Article 35 — Data Protection Impact Assessment"}],["$","p",null,{"className":"text-sm text-muted","children":"High-risk processing requires a DPIA. Codepliant generates PIA/DPIA documents based on the data practices detected in your code."}]]}]
