f:["$","div","MAP — Identify and categorize AI systems",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"MAP — Identify and categorize AI systems"}],["$","p",null,{"className":"text-sm text-muted","children":"Catalog all AI usage in your application. Codepliant creates a model inventory, maps AI features to EU AI Act risk tiers, and documents intended use cases and known limitations."}]]}]
10:["$","div","MEASURE — Assess AI risks",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"MEASURE — Assess AI risks"}],["$","p",null,{"className":"text-sm text-muted","children":"Quantify risks associated with your AI systems. Codepliant generates risk assessments covering bias, reliability, transparency, privacy, and security for each detected AI integration."}]]}]
11:["$","div","MANAGE — Mitigate and monitor",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"MANAGE — Mitigate and monitor"}],["$","p",null,{"className":"text-sm text-muted","children":"Implement ongoing risk management. Codepliant documents your monitoring setup, logging configurations, and human oversight mechanisms for AI-powered features."}]]}]
12:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"EU AI Act compliance by risk level"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"The EU AI Act categorizes AI systems into risk tiers, each with different obligations. Codepliant analyzes your AI integrations and determines which tier applies to your use case:"}],["$","div",null,{"className":"space-y-4","children":[["$","div","Minimal Risk",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"Minimal Risk"}],["$","p",null,{"className":"text-sm text-muted","children":"Most SaaS AI features (content generation, search, recommendations). Requires transparency disclosures. Codepliant generates Article 50 transparency notices and AI usage disclosures."}]]}],["$","div","Limited Risk",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"Limited Risk"}],["$","p",null,{"className":"text-sm text-muted","children":"AI systems that interact directly with users (chatbots, deepfake generators). Requires user notification. Codepliant generates interaction disclosure notices and chatbot labeling documentation."}]]}],["$","div","High-Risk",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"High-Risk"}],["$","p",null,{"className":"text-sm text-muted","children":"AI in hiring, credit scoring, critical infrastructure, education, and law enforcement. Requires conformity assessments, risk management systems, and human oversight. Codepliant generates the full documentation package."}]]}]]}]]}]]}]
13:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"AI governance documents Codepliant generates"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","div","AI Model Inventory",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"AI Model Inventory"}],["$","div","AI Risk Assessment",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"AI Risk Assessment"}],["$","div","AI Acceptable Use Policy",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"AI Acceptable Use Policy"}],["$","div","Transparency Notice (Art. 50)",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Transparency Notice (Art. 50)"}],["$","div","AI Disclosure Statement",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"AI Disclosure Statement"}],["$","div","Model Governance Charter",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Model Governance Charter"}],["$","div","Bias & Fairness Report",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Bias & Fairness Report"}],["$","div","Human Oversight Documentation",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Human Oversight Documentation"}],["$","div","AI Data Governance Plan",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"AI Data Governance Plan"}],["$","div","Conformity Assessment (High-Risk)",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Conformity Assessment (High-Risk)"}]]}]]}]
14:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Why AI governance matters now"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"The EU AI Act's transparency obligations (Article 50) take effect on August 2, 2026. Companies deploying AI systems in the EU — including SaaS products accessible to EU users — must comply or face fines up to 3% of global annual turnover."}],["$","p",null,{"children":"In the US, the NIST AI RMF is increasingly referenced in federal procurement requirements and state-level AI legislation. Companies that adopt AI governance frameworks early gain a competitive advantage in enterprise sales, where buyers now include AI governance in vendor assessments."}],["$","p",null,{"children":"Codepliant makes AI risk management practical for engineering teams. Instead of hiring a dedicated AI governance officer or engaging a consulting firm, run a single command to generate framework-aligned documentation from your actual AI implementation."}]]}]]}]
