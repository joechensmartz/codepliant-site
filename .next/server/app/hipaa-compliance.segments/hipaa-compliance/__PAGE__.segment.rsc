2:T649,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What types of health data does Codepliant detect?","acceptedAnswer":{"@type":"Answer","text":"Codepliant identifies all 18 HIPAA identifiers in your database schemas and data models, including names, dates, Social Security numbers, medical record numbers, health plan IDs, and biometric data. It also detects PHI in API request/response schemas and form fields."}},{"@type":"Question","name":"Does Codepliant make my app HIPAA compliant?","acceptedAnswer":{"@type":"Answer","text":"Codepliant generates the documentation required by HIPAA, but compliance also requires administrative safeguards, physical safeguards, and organizational requirements. Use Codepliant alongside your security program to handle the technical documentation efficiently."}},{"@type":"Question","name":"Can Codepliant detect if PHI is being transmitted insecurely?","acceptedAnswer":{"@type":"Answer","text":"Yes. Codepliant analyzes your API endpoints, database connections, and third-party integrations to identify whether PHI is encrypted in transit and at rest. It flags unencrypted connections and missing TLS configurations."}},{"@type":"Question","name":"Do I need HIPAA compliance if I use a HIPAA-compliant cloud provider?","acceptedAnswer":{"@type":"Answer","text":"Yes. Using a HIPAA-compliant hosting provider (AWS, GCP, Azure) is necessary but not sufficient. You are still responsible for how your application handles PHI at the code level — access controls, encryption, audit logging, and proper BAAs with all vendors."}}]}0:{"buildId":"exy9jj33WJFGOjGJaKMQN","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Codepliant HIPAA Compliance Tool\",\"applicationCategory\":\"DeveloperApplication\",\"operatingSystem\":\"macOS, Linux, Windows\",\"description\":\"HIPAA compliance tool that scans your codebase to detect PHI handling and generate required documentation automatically.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}"}}],["$","article",null,{"className":"py-20 px-6","children":["$","div",null,{"className":"max-w-[680px] mx-auto","children":[["$","p",null,{"className":"text-sm font-medium text-accent mb-4 tracking-wide uppercase","children":"HIPAA Compliance"}],["$","h1",null,{"className":"text-4xl font-bold tracking-tight mb-6","children":"HIPAA Compliance Tool for Healthcare Apps"}],["$","p",null,{"className":"text-lg text-muted mb-12","children":"Building a healthcare application means handling Protected Health Information (PHI) under strict federal regulations. Codepliant scans your codebase to detect health data collection patterns, identify compliance gaps, and generate the documentation HIPAA requires — from risk assessments to Business Associate Agreements."}],["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"HIPAA technical safeguard requirements"}],["$","div",null,{"className":"space-y-4","children":[["$","div","164.312(a) — Access controls",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"164.312(a) — Access controls"}],["$","p",null,{"className":"text-sm text-muted","children":"Implement technical policies to restrict access to ePHI. Codepliant detects authentication mechanisms, role-based access, and session management in your codebase to document your access control implementation."}]]}],"$L3","$L4","$L5"]}]]}],"$L6","$L7","$L8","$L9","$La"]}]}]],null,"$Lb"]}],"loading":null,"isPartial":false}
3:["$","div","164.312(c) — Integrity controls",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"164.312(c) — Integrity controls"}],["$","p",null,{"className":"text-sm text-muted","children":"Protect ePHI from improper alteration or destruction. Codepliant identifies input validation, audit logging, and data integrity mechanisms in your application code."}]]}]
4:["$","div","164.312(d) — Person or entity authentication",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"164.312(d) — Person or entity authentication"}],["$","p",null,{"className":"text-sm text-muted","children":"Verify that users accessing ePHI are who they claim to be. Codepliant detects your authentication flows, MFA implementations, and identity provider integrations."}]]}]
5:["$","div","164.312(e) — Transmission security",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"164.312(e) — Transmission security"}],["$","p",null,{"className":"text-sm text-muted","children":"Guard against unauthorized access to ePHI during transmission. Codepliant checks for TLS configuration, encrypted API endpoints, and secure data transfer mechanisms."}]]}]
6:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"How Codepliant detects health data in your code"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"HIPAA defines 18 types of identifiers that constitute PHI when linked to health information. Codepliant scans your ORM schemas, API definitions, form handlers, and database migrations to identify fields that match these identifiers — names, dates of birth, Social Security numbers, medical record numbers, device identifiers, and more."}],["$","p",null,{"children":"Beyond schema detection, Codepliant analyzes your data flow patterns. It traces how health data moves from user input through your application to storage and third-party services. This analysis identifies potential exposure points where PHI could be logged, cached, or transmitted without proper safeguards."}],["$","p",null,{"children":"The healthcare app compliance scanner also detects common healthcare integrations — HL7 FHIR APIs, EHR system connections, insurance claim processors, and telehealth SDKs — to build a complete picture of your application's health data ecosystem."}]]}]]}]
7:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"HIPAA documentation Codepliant generates"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","div","HIPAA Risk Assessment",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"HIPAA Risk Assessment"}],["$","div","Business Associate Agreement",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Business Associate Agreement"}],["$","div","PHI Data Flow Map",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"PHI Data Flow Map"}],["$","div","Access Control Policy",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Access Control Policy"}],["$","div","Encryption Documentation",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Encryption Documentation"}],["$","div","Audit Log Requirements",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Audit Log Requirements"}],["$","div","Breach Notification Plan",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Breach Notification Plan"}],["$","div","Workforce Training Guide",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Workforce Training Guide"}],["$","div","Minimum Necessary Standard",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Minimum Necessary Standard"}],["$","div","Compliance Gap Analysis",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Compliance Gap Analysis"}]]}]]}]
8:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Why healthcare app developers need compliance tooling"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"HIPAA violations carry penalties from $100 to $50,000 per violation, with an annual maximum of $1.5 million per violation category. The HHS Office for Civil Rights investigated over 1,000 cases in 2025 alone, and the most common finding was inadequate risk analysis — exactly what Codepliant automates."}],["$","p",null,{"children":"Digital health startups face a unique challenge: they need to move fast to compete, but HIPAA demands thorough documentation and risk management. Codepliant bridges this gap by generating compliance documentation from your actual code, ensuring your documentation stays accurate as your application evolves."}]]}]]}]
