e:T753,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is Article 50 of the EU AI Act?","acceptedAnswer":{"@type":"Answer","text":"Article 50 of the EU AI Act establishes transparency obligations for providers and deployers of AI systems. It requires that users are informed when they are interacting with AI, when content is AI-generated, and when AI systems are used for decision-making that affects them."}},{"@type":"Question","name":"When does Article 50 take effect?","acceptedAnswer":{"@type":"Answer","text":"Article 50 transparency obligations take effect on August 2, 2026. Organizations using AI in products or services available to EU citizens must comply by this date."}},{"@type":"Question","name":"Does the EU AI Act apply to my application?","acceptedAnswer":{"@type":"Answer","text":"If your application uses AI and is accessible to users in the EU, you likely need to comply. This includes chatbots, AI-generated content, recommendation systems, automated decision-making, and any feature powered by large language models like GPT-4, Claude, or open source models."}},{"@type":"Question","name":"What AI integrations does Codepliant detect?","acceptedAnswer":{"@type":"Answer","text":"Codepliant detects OpenAI API, Anthropic Claude, Google AI/Gemini, Hugging Face, Replicate, Cohere, AI21 Labs, Stability AI, local model inference (ONNX, TensorFlow, PyTorch), LangChain, and other AI/ML frameworks in your codebase."}},{"@type":"Question","name":"What documents does Codepliant generate for AI compliance?","acceptedAnswer":{"@type":"Answer","text":"Codepliant generates AI Disclosure documents, AI Checklists, AI Model Cards, and includes AI-related sections in your privacy policy. These documents cover Article 50 requirements including transparency notices, capability descriptions, and risk assessments."}}]}b:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$e"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Codepliant AI Disclosure Generator\",\"applicationCategory\":\"DeveloperApplication\",\"operatingSystem\":\"macOS, Linux, Windows\",\"description\":\"Generate EU AI Act Article 50 compliant AI disclosures by scanning your codebase for AI integrations.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}"}}],["$","article",null,{"className":"py-20 px-6","children":["$","div",null,{"className":"max-w-[680px] mx-auto","children":[["$","div",null,{"className":"bg-warning/10 text-warning rounded-2xl p-6 text-center mb-12","children":[["$","div",null,{"className":"text-5xl font-bold mb-1","children":140}],["$","div",null,{"className":"text-sm font-medium","children":"days until EU AI Act Article 50 takes effect"}],["$","div",null,{"className":"text-xs mt-1 opacity-70","children":"August 2, 2026"}]]}],["$","p",null,{"className":"text-sm font-medium text-accent mb-4 tracking-wide uppercase","children":"EU AI Act Compliance"}],["$","h1",null,{"className":"text-4xl font-bold tracking-tight mb-6","children":"EU AI Act Compliance Tool — AI Disclosure Generator"}],["$","p",null,{"className":"text-lg text-muted mb-12","children":"Article 50 of the EU AI Act requires transparency when users interact with AI systems. Codepliant scans your codebase, detects AI integrations, and generates the required disclosure documents automatically."}],"$Lf","$L10","$L11","$L12","$L13"]}]}]],null,"$L14"]}]
