f:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Article 50 requirements explained"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"The EU AI Act is the world's first comprehensive AI regulation. Article 50 specifically addresses transparency obligations that apply to a wide range of AI systems, not just high-risk ones."}],["$","div",null,{"className":"space-y-4","children":[["$","div",null,{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"AI interaction disclosure"}],["$","p",null,{"className":"text-sm","children":"Users must be informed when they are interacting with an AI system (e.g., chatbots, virtual assistants). The disclosure must be clear, timely, and in a format the user can understand."}]]}],["$","div",null,{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"AI-generated content labeling"}],["$","p",null,{"className":"text-sm","children":"Content generated or manipulated by AI (text, images, audio, video) must be marked as such. This applies to deepfakes, synthetic media, and AI-written content."}]]}],["$","div",null,{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"Emotion recognition & biometric categorization"}],["$","p",null,{"className":"text-sm","children":"Systems that use emotion recognition or biometric categorization must inform the individuals being analyzed."}]]}],["$","div",null,{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"Automated decision-making"}],["$","p",null,{"className":"text-sm","children":"When AI is used to make or assist decisions that affect individuals, transparency about the AI's role is required."}]]}]]}]]}]]}]
