11:["$","div","CC8 — Change management",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"CC8 — Change management"}],["$","p",null,{"className":"text-sm text-muted","children":"Document your change management process. Codepliant analyzes your CI/CD configuration, code review requirements, and deployment pipelines."}]]}]
12:["$","div","CC9 — Risk mitigation",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-2","children":"CC9 — Risk mitigation"}],["$","p",null,{"className":"text-sm text-muted","children":"Prove you identify and mitigate risks. Codepliant generates a risk assessment based on third-party dependencies, data handling patterns, and infrastructure configuration."}]]}]
13:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"SOC 2 documentation Codepliant generates"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","div","SOC 2 Readiness Checklist",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"SOC 2 Readiness Checklist"}],["$","div","Control-to-Criteria Mapping",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Control-to-Criteria Mapping"}],["$","div","Access Control Evidence",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Access Control Evidence"}],["$","div","Encryption Inventory",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Encryption Inventory"}],["$","div","Third-Party Vendor List",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Third-Party Vendor List"}],["$","div","Change Management Summary",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Change Management Summary"}],["$","div","Logging & Monitoring Report",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Logging & Monitoring Report"}],["$","div","Data Flow Diagram",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Data Flow Diagram"}],["$","div","Risk Assessment",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Risk Assessment"}],["$","div","Compliance Gap Analysis",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Compliance Gap Analysis"}]]}]]}]
14:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"How Codepliant automates SOC 2 preparation"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"SOC 2 automation starts with understanding what your application actually does. Codepliant performs static analysis across your entire codebase to identify security controls, data handling patterns, and infrastructure configuration. It detects encryption at rest and in transit, authentication mechanisms (OAuth, JWT, session-based), role-based access controls, input validation, and logging frameworks."}],["$","p",null,{"children":"From this analysis, Codepliant maps your existing controls to SOC 2 Trust Service Criteria. The readiness checklist shows which controls you already satisfy and which gaps remain. The control mapping document provides the evidence narrative your auditor needs — with references to specific files and configurations in your codebase."}],["$","p",null,{"children":"For startups pursuing their first SOC 2 Type I report, Codepliant reduces preparation time from months to days. Instead of manually documenting every control, your engineering team runs a single command and gets audit-ready documentation that reflects your actual implementation."}]]}]]}]
15:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Why startups need SOC 2 compliance"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"Enterprise sales cycles stall without SOC 2. According to Vanta's 2025 Trust Report, 76% of enterprise procurement teams require SOC 2 Type II before signing a contract. For startups selling to mid-market and enterprise customers, SOC 2 is not optional — it is a revenue gate."}],["$","p",null,{"children":"The traditional path to SOC 2 involves hiring a compliance consultant ($20,000-$50,000), purchasing a GRC platform ($10,000-$30,000/year), and dedicating engineering time for 3-6 months. Codepliant eliminates the documentation bottleneck, which is typically the most time-consuming part for engineering teams."}]]}]]}]
