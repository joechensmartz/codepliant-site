44:"$Sreact.suspense"
2:T487,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"When does the EU AI Act take effect?","acceptedAnswer":{"@type":"Answer","text":"The EU AI Act entered into force on August 1, 2024. Prohibited AI practices applied from February 2, 2025. Transparency obligations under Article 50 take effect August 2, 2026. High-risk AI system requirements apply from August 2, 2027."}},{"@type":"Question","name":"Does the EU AI Act apply to companies outside the EU?","acceptedAnswer":{"@type":"Answer","text":"Yes. The EU AI Act has extraterritorial scope. It applies to any organization that places AI systems on the EU market or whose AI system output is used in the EU, regardless of where the organization is based."}},{"@type":"Question","name":"What are the penalties for non-compliance with the EU AI Act?","acceptedAnswer":{"@type":"Answer","text":"Fines range from 7.5 million EUR or 1% of global turnover (for incorrect information) to 35 million EUR or 7% of global turnover (for prohibited AI practices). For most SaaS companies, transparency violations carry fines up to 15 million EUR or 3% of global turnover."}}]}0:{"buildId":"3_8tk2yXshjsX4BxM6gAi","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"EU AI Act: What Developers Need to Know Before August 2, 2026\",\"description\":\"Comprehensive developer guide to the EU AI Act. Risk classifications, transparency obligations, compliance timelines, and practical preparation steps.\",\"datePublished\":\"2026-03-15\",\"dateModified\":\"2026-03-15\",\"author\":{\"@type\":\"Organization\",\"name\":\"Codepliant\",\"url\":\"https://codepliant.dev\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Codepliant\",\"url\":\"https://codepliant.dev\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://codepliant.dev/blog/eu-ai-act-deadline\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","article",null,{"className":"py-20 px-6","children":["$","div",null,{"className":"max-w-[680px] mx-auto","children":[["$","p",null,{"className":"text-sm font-medium text-accent mb-4 tracking-wide uppercase","children":"Blog"}],["$","h1",null,{"className":"text-4xl font-bold tracking-tight mb-4","children":"EU AI Act: What Developers Need to Know Before August 2, 2026"}],["$","p",null,{"className":"text-sm text-muted mb-12","children":"Published March 15, 2026 · 12 min read"}],["$","div",null,{"className":"prose-custom space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"The EU AI Act is the world's first comprehensive legal framework for artificial intelligence. If you build software that uses AI — and in 2026, that means most SaaS products — you need to understand what the Act requires and when those requirements kick in. The most immediately relevant deadline for developers is August 2, 2026, when Article 50 transparency obligations become enforceable."}],["$","p",null,{"children":"This guide covers everything developers need to know: the regulatory timeline, risk classification system, specific obligations by risk tier, practical compliance steps, and what happens if you do not comply. Whether you are integrating OpenAI APIs, running fine-tuned models, or building AI features from scratch, this article will help you prepare."}],["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"The EU AI Act timeline: key dates for developers"}],"$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f"]}],"$L40","$L41"]}]}]],null,"$L42"]}],"loading":null,"isPartial":false}
3:["$","p",null,{"children":"The EU AI Act was published in the Official Journal of the European Union on July 12, 2024, and entered into force on August 1, 2024. But the obligations phase in gradually over three years:"}]
4:["$","div",null,{"className":"space-y-4","children":[["$","div","February 2, 2025",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["February 2, 2025"," — ","Prohibited AI practices"]}],["$","p",null,{"className":"text-sm text-muted","children":"AI systems that pose unacceptable risks are banned. This includes social scoring systems, real-time biometric identification in public spaces (with exceptions), manipulation techniques that exploit vulnerabilities, and emotion recognition in workplaces and education."}]]}],["$","div","August 2, 2025",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["August 2, 2025"," — ","Governance and general-purpose AI"]}],["$","p",null,{"className":"text-sm text-muted","children":"National competent authorities must be designated. Rules for general-purpose AI (GPAI) models begin to apply, including transparency and copyright obligations for GPAI providers like OpenAI and Anthropic."}]]}],["$","div","August 2, 2026",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["August 2, 2026"," — ","Transparency obligations (Article 50)"]}],["$","p",null,{"className":"text-sm text-muted","children":"This is the critical deadline for most developers. All AI systems that interact with people, generate synthetic content, or make decisions affecting individuals must include transparency measures. If your SaaS uses AI, this applies to you."}]]}],["$","div","August 2, 2027",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["August 2, 2027"," — ","High-risk AI system requirements"]}],["$","p",null,{"className":"text-sm text-muted","children":"Full compliance requirements for high-risk AI systems, including conformity assessments, quality management systems, post-market monitoring, and registration in the EU database."}]]}]]}]
5:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Understanding the risk classification system"}]
6:["$","p",null,{"children":"The EU AI Act takes a risk-based approach. Your obligations depend on which risk tier your AI system falls into. Understanding your classification is the first step toward compliance."}]
7:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Unacceptable Risk (Prohibited)"}]
8:["$","p",null,{"children":"These AI practices are banned outright, effective February 2025. They include social scoring by governments, real-time remote biometric identification in public spaces (with narrow law enforcement exceptions), AI that manipulates behavior to cause harm, and systems that exploit age, disability, or social situations."}]
9:["$","p",null,{"children":"As a developer, verify that none of your AI features fall into this category. Most SaaS applications do not, but edge cases exist. For example, an AI-powered hiring tool that infers emotional states from video interviews could be classified as prohibited emotion recognition in the workplace."}]
a:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"High Risk"}]
b:["$","p",null,{"children":"High-risk AI systems have the most extensive obligations. These include AI used in hiring and recruitment, credit scoring and insurance, education (admissions, grading), critical infrastructure, law enforcement, border control, and access to essential services."}]
c:["$","p",null,{"children":"If your AI system is classified as high-risk, you must implement a risk management system, ensure data governance with training data documentation, maintain technical documentation, enable human oversight, achieve accuracy and robustness standards, and register in the EU AI database. The full requirements take effect August 2, 2027, but preparation should start now."}]
d:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Limited Risk (Transparency Obligations)"}]
e:["$","p",null,{"children":"This is where most SaaS AI features land. Limited-risk systems are subject to Article 50 transparency obligations, effective August 2, 2026. These include:"}]
f:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"AI-generated content labeling:"}]," Users must be informed when content (text, images, audio, video) is generated by AI. This applies to chatbots, AI writing assistants, image generators, and any feature that produces synthetic content."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Chatbot disclosure:"}]," When a user interacts with an AI system, they must be informed they are interacting with AI, not a human. This includes customer support chatbots, virtual assistants, and AI agents."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Deepfake labeling:"}]," AI-generated or manipulated images, audio, or video must be labeled as artificially generated. This includes AI avatars, voice synthesis, and image editing tools."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Emotion recognition disclosure:"}]," If your system detects emotions or biometric categorization, users must be informed (though many emotion recognition uses are prohibited entirely)."]}]]}]
10:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Minimal Risk"}]
11:["$","p",null,{"children":"AI systems that pose minimal risk — spam filters, AI-powered search, recommendation engines, inventory management — have no mandatory obligations under the Act. However, the European Commission encourages voluntary codes of conduct for these systems, and best practice suggests documenting AI usage even when not legally required."}]
12:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"What Article 50 means in practice for your application"}]
13:["$","p",null,{"children":"Article 50 is the section most relevant to SaaS developers in 2026. Let us break down what it requires in concrete terms."}]
14:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"1. Disclose AI-generated content"}]
15:["$","p",null,{"children":"If your application generates text, images, audio, or video using AI, you must clearly inform users that the content is AI-generated. This applies whether you use OpenAI, Anthropic, Mistral, Llama, or any other AI provider."}]
16:["$","p",null,{"children":"Practically, this means adding visible labels or disclosures near AI-generated content. A writing assistant should indicate which portions were AI-generated. An image generation tool must label outputs as AI-generated. A code assistant should distinguish AI suggestions from human-written code."}]
17:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"2. Identify AI interactions"}]
18:["$","p",null,{"children":"If your application includes a chatbot, virtual assistant, or any feature where AI communicates with users in natural language, you must inform users that they are interacting with an AI system. This must happen before or at the start of the interaction."}]
19:["$","p",null,{"children":"A simple implementation is a banner or notice at the top of the chat interface stating \"You are interacting with an AI assistant.\" The disclosure must be clear, concise, and impossible to miss."}]
1a:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"3. Mark synthetic media"}]
1b:["$","p",null,{"children":"AI-generated or substantially modified images, audio, and video must be labeled as such. The Act requires both human-readable disclosures (visible labels) and machine-readable markings (metadata, watermarks). This means implementing both UI labeling and technical watermarking for any synthetic media your application produces."}]
1c:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"4. Document your AI systems"}]
1d:["$","p",null,{"children":"While not explicitly an Article 50 requirement, the broader AI Act expects organizations to maintain documentation of their AI systems. This includes what AI models you use, what data they process, what decisions they influence, and what safeguards you have in place. Maintaining this documentation from the start makes compliance with future obligations significantly easier."}]
1e:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Extraterritorial scope: why this affects non-EU companies"}]
1f:["$","p",null,{"children":"Like GDPR before it, the EU AI Act has extraterritorial reach. Article 2 establishes that the Act applies to:"}]
20:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":"Providers who place AI systems on the EU market, regardless of where they are established"}],["$","li",null,{"children":"Deployers of AI systems located within the EU"}],["$","li",null,{"children":"Providers and deployers located outside the EU, where the output produced by the AI system is used in the EU"}]]}]
21:["$","p",null,{"children":"If your SaaS product is accessible to EU users and includes AI features, you are likely within scope. This mirrors how GDPR applies to any company processing data of EU residents, and companies that ignored GDPR's extraterritorial scope learned expensive lessons."}]
22:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Penalties for non-compliance"}]
23:["$","p",null,{"children":"The EU AI Act introduces a tiered penalty structure based on the severity of the violation:"}]
24:["$","div",null,{"className":"space-y-4","children":[["$","div","Prohibited AI practices",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Prohibited AI practices"}],["$","p",null,{"className":"text-sm text-muted","children":"Up to 35 million EUR or 7% of global annual turnover, whichever is higher"}]]}],["$","div","High-risk system obligations",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"High-risk system obligations"}],["$","p",null,{"className":"text-sm text-muted","children":"Up to 15 million EUR or 3% of global annual turnover"}]]}],["$","div","Transparency obligations (Article 50)",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Transparency obligations (Article 50)"}],["$","p",null,{"className":"text-sm text-muted","children":"Up to 15 million EUR or 3% of global annual turnover"}]]}],["$","div","Incorrect information to authorities",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Incorrect information to authorities"}],["$","p",null,{"className":"text-sm text-muted","children":"Up to 7.5 million EUR or 1% of global annual turnover"}]]}]]}]
25:["$","p",null,{"className":"pt-4","children":"For SMEs and startups, fines are capped proportionally. But even proportional fines based on 3% of turnover can be significant. More practically, non-compliance creates business risk: enterprise customers increasingly require AI governance as part of vendor assessments."}]
26:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"General-purpose AI model rules: what API consumers need to know"}]
27:["$","p",null,{"children":"The AI Act introduces specific obligations for providers of general-purpose AI (GPAI) models — companies like OpenAI, Anthropic, Google, and Meta. These obligations include publishing model documentation, complying with EU copyright law, and implementing safety testing for models with systemic risk."}]
28:["$","p",null,{"children":"As a developer consuming these APIs, you do not bear the GPAI provider obligations directly. However, you benefit from understanding them. GPAI providers must give you sufficient documentation to fulfill your own downstream obligations. Practically, this means OpenAI and Anthropic will publish technical documentation, model cards, and usage policies that you should reference in your own compliance documentation."}]
29:["$","p",null,{"children":"Importantly, using a GPAI API does not exempt you from deployer obligations. You remain responsible for how you use the AI output, what disclosures you provide to your users, and what risks your specific application introduces."}]
2a:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Practical compliance steps for developers"}]
2b:["$","p",null,{"children":"With the August 2, 2026 deadline approaching, here is a practical checklist for engineering teams:"}]
2c:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Step 1: Inventory your AI usage"}]
2d:["$","p",null,{"children":"Catalog every AI integration in your application. This includes direct API calls to AI providers, embedded ML models, AI-powered features in third-party libraries, and any automated decision-making systems. Codepliant automates this step by scanning your codebase and generating a complete AI model inventory."}]
2e:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Step 2: Classify your risk level"}]
2f:["$","p",null,{"children":"For each AI system or feature, determine which risk tier applies. Most SaaS AI features (content generation, search, chatbots, recommendations) fall under limited risk with transparency obligations. If you are in hiring, credit, education, or healthcare, you may be high-risk."}]
30:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Step 3: Implement transparency measures"}]
31:["$","p",null,{"children":"For the August 2026 deadline, focus on Article 50 transparency: add AI-generated content labels, chatbot disclosures, synthetic media marking, and general AI usage notices. These are UI changes that your engineering team can implement directly."}]
32:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Step 4: Generate compliance documentation"}]
33:["$","p",null,{"children":"Document your AI systems, their purposes, risk assessments, and transparency measures. This documentation serves as evidence of compliance and is required for high-risk systems. Codepliant generates this documentation from your codebase, including AI disclosure statements, risk assessments, and model inventories."}]
34:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Step 5: Establish ongoing governance"}]
35:["$","p",null,{"children":"Compliance is not a one-time event. Establish processes for reviewing AI usage when adding new features, updating documentation when AI integrations change, monitoring AI system performance and risks, and responding to user complaints about AI decisions. Integrate Codepliant into your CI/CD pipeline to regenerate compliance documentation on every deployment."}]
36:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Lessons from GDPR: why early preparation matters"}]
37:["$","p",null,{"children":"The EU AI Act follows the same enforcement playbook as GDPR. When GDPR took effect in May 2018, many companies assumed enforcement would be slow and limited. Eight years later, over 2,000 fines totaling more than 4.5 billion EUR have been issued. Meta alone has been fined over 2.5 billion EUR for GDPR violations."}]
38:["$","p",null,{"children":"The AI Act enforcement is expected to follow a similar pattern: initial guidance and warnings, followed by increasing enforcement activity. Companies that prepare now will avoid both financial penalties and the reputational damage of being an early enforcement target."}]
39:["$","p",null,{"children":"GDPR also showed that compliance creates competitive advantage. Companies with strong data privacy practices win enterprise deals faster. The same dynamic is already emerging with AI governance — procurement teams at large organizations are adding AI compliance requirements to their vendor assessment questionnaires."}]
3a:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Impact by industry"}]
3b:["$","p",null,{"children":"The AI Act affects different industries differently. Here is how common SaaS verticals are impacted:"}]
3c:["$","div",null,{"className":"space-y-4","children":[["$","div","Developer tools and AI coding assistants",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Developer tools and AI coding assistants"}],["$","p",null,{"className":"text-sm text-muted","children":"Limited risk. Must disclose AI-generated code suggestions and label AI-assisted outputs. Implement transparency notices in IDE plugins and API responses."}]]}],["$","div","Customer support and chatbots",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Customer support and chatbots"}],["$","p",null,{"className":"text-sm text-muted","children":"Limited risk. Must inform users they are interacting with AI before or at the start of the conversation. Requires clear chatbot labeling."}]]}],["$","div","Content creation and marketing tools",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Content creation and marketing tools"}],["$","p",null,{"className":"text-sm text-muted","children":"Limited risk. Must label AI-generated text, images, and video. Both human-readable labels and machine-readable metadata required for media content."}]]}],["$","div","HR tech and recruitment platforms",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"HR tech and recruitment platforms"}],["$","p",null,{"className":"text-sm text-muted","children":"High risk. AI used in hiring decisions requires conformity assessments, risk management systems, human oversight, and registration in the EU database. Full requirements by August 2027."}]]}],["$","div","Fintech and lending platforms",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Fintech and lending platforms"}],["$","p",null,{"className":"text-sm text-muted","children":"High risk. AI used in credit scoring or insurance decisions has extensive documentation, testing, and oversight requirements. Must enable human review of AI decisions."}]]}],["$","div","Healthcare and medtech",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Healthcare and medtech"}],["$","p",null,{"className":"text-sm text-muted","children":"High risk. AI in medical diagnosis, treatment recommendations, or health monitoring requires conformity assessments and is also subject to HIPAA in the US market."}]]}]]}]
3d:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"What to do right now"}]
3e:["$","p",null,{"children":"You have less than five months until Article 50 obligations become enforceable. Here is what your engineering team should prioritize:"}]
3f:["$","ol",null,{"className":"list-decimal list-inside space-y-3 ml-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Run an AI audit."}]," Use Codepliant to scan your codebase and generate a complete AI inventory. Understand exactly what AI systems your application uses and how they process data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Add transparency disclosures."}]," Implement AI-generated content labels, chatbot notices, and AI usage disclosures in your UI. These are the minimum requirements for August 2026."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Generate compliance documentation."}]," Use Codepliant to produce AI disclosure statements, risk assessments, and governance frameworks aligned with both the EU AI Act and the NIST AI RMF."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Brief your legal team."}]," Share this guide and your AI inventory with legal counsel. They can help determine your exact risk classification and identify any high-risk use cases that need additional preparation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Integrate into CI/CD."}]," Add Codepliant to your deployment pipeline so compliance documentation updates automatically as your AI integrations evolve."]}]]}]
40:["$","section",null,{"className":"bg-surface rounded-2xl p-8 text-center mt-16 mb-16","children":[["$","h2",null,{"className":"text-xl font-bold mb-3","children":"Prepare for the EU AI Act deadline"}],["$","p",null,{"className":"text-muted text-sm mb-6","children":"Scan your codebase to generate AI governance documentation. Free, open source, no account required."}],["$","div",null,{"className":"bg-code-bg text-code-fg px-6 py-3 rounded-xl font-mono text-sm inline-block","children":"npx codepliant go"}]]}]
