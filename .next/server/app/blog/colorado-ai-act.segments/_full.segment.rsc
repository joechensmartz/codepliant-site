a:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Colorado AI Act: What SaaS Companies Need to Know\",\"description\":\"Guide to the Colorado AI Act (SB 24-205) for SaaS companies. Covers high-risk AI system requirements, algorithmic discrimination prevention, impact assessments, and compliance steps.\",\"datePublished\":\"2026-03-16\",\"dateModified\":\"2026-03-16\",\"author\":{\"@type\":\"Organization\",\"name\":\"Codepliant\",\"url\":\"https://codepliant.dev\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Codepliant\",\"url\":\"https://codepliant.dev\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://codepliant.dev/blog/colorado-ai-act\"}}"}}],["$","article",null,{"className":"py-20 px-6","children":["$","div",null,{"className":"max-w-[680px] mx-auto","children":[["$","p",null,{"className":"text-sm font-medium text-accent mb-4 tracking-wide uppercase","children":"Blog"}],["$","h1",null,{"className":"text-4xl font-bold tracking-tight mb-4","children":"Colorado AI Act: What SaaS Companies Need to Know"}],["$","p",null,{"className":"text-sm text-muted mb-12","children":"Published March 16, 2026 · 14 min read"}],["$","div",null,{"className":"prose-custom space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"Colorado Senate Bill 24-205, known as the Colorado AI Act, is the first comprehensive state-level AI regulation in the United States. Signed into law in May 2024, it takes effect on February 1, 2026, with a compliance deadline of June 30, 2026 for companies to complete their initial impact assessments. If your SaaS application uses AI to make or substantially influence decisions that affect Colorado residents, this law applies to you."}],["$","p",null,{"children":"While the EU AI Act gets most of the attention, the Colorado AI Act is more immediately relevant for US-based SaaS companies. It creates concrete obligations around algorithmic discrimination prevention, impact assessments, transparency disclosures, and governance practices. And unlike federal AI guidance, it has enforcement teeth: the Colorado Attorney General can bring actions against non-compliant companies."}],["$","p",null,{"children":"This guide covers what the Colorado AI Act requires, who it applies to, what the deadlines are, and what your engineering and product teams need to do to comply."}],["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"What is the Colorado AI Act (SB 24-205)?"}],["$","p",null,{"children":"The Colorado AI Act regulates \"high-risk artificial intelligence systems\" — AI systems that make or are a substantial factor in making consequential decisions about Colorado residents. It applies to both developers (companies that build AI systems) and deployers (companies that use AI systems in their products or operations)."}],["$","p",null,{"children":"The Act focuses specifically on preventing algorithmic discrimination — the use of AI in ways that result in unlawful differential treatment based on protected characteristics including age, race, sex, disability, religion, sexual orientation, gender identity, and veteran status."}],["$","p",null,{"children":"Unlike broader AI regulations, the Colorado AI Act is narrow in scope but deep in requirements. It does not attempt to regulate all AI — only high-risk systems that affect consequential decisions. But for those systems, the obligations are substantial."}],"$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c"]}],"$L3d","$L3e"]}]}]],null,"$L3f"]}]
b:["$","$1","h",{"children":[null,["$","$L40",null,{"children":"$L41"}],["$","div",null,{"hidden":true,"children":["$","$L42",null,{"children":["$","$43",null,{"name":"Next.Metadata","children":"$L44"}]}]}],["$","meta",null,{"name":"next-size-adjust","content":""}]]}]
45:I[97367,["/_next/static/chunks/2f236954d6a65e12.js"],"OutletBoundary"]
d:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Who does the Colorado AI Act apply to?"}]
e:["$","p",null,{"children":"The Act applies to two categories of entities:"}]
f:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Developers"}]
10:["$","p",null,{"children":"A developer is any entity that creates, codes, or substantially modifies an AI system. If you build AI features into your SaaS product, you are likely a developer under the Act. This includes companies that fine-tune foundation models, build custom ML models, or create AI-powered features that influence decisions."}]
11:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"Deployers"}]
12:["$","p",null,{"children":"A deployer is any entity that uses a high-risk AI system to make consequential decisions. If your SaaS product is used by businesses in Colorado to make decisions about their customers or employees, both you and your customers may be deployers. This is critical for B2B SaaS: even if your company is not based in Colorado, if your customers use your AI features to make decisions about Colorado residents, the Act applies."}]
13:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"What counts as a consequential decision?"}]
14:["$","p",null,{"children":"The Act defines consequential decisions as those with material legal or similarly significant effects on individuals in these areas:"}]
15:["$","div",null,{"className":"space-y-4","children":[["$","div","Employment",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Employment"}],["$","p",null,{"className":"text-sm text-muted","children":"Hiring, termination, promotion, compensation, performance evaluation, disciplinary actions. AI-powered resume screening, candidate ranking, and performance analytics all qualify."}]]}],["$","div","Education",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Education"}],["$","p",null,{"className":"text-sm text-muted","children":"Admissions, financial aid, grading, disciplinary decisions, academic opportunity allocation. AI-driven tutoring systems that determine curriculum paths may qualify."}]]}],["$","div","Financial services",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Financial services"}],["$","p",null,{"className":"text-sm text-muted","children":"Lending, credit, insurance underwriting, investment advice. AI-powered credit scoring, fraud detection that blocks transactions, and insurance pricing all qualify."}]]}],["$","div","Housing",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Housing"}],["$","p",null,{"className":"text-sm text-muted","children":"Tenant screening, rental pricing, mortgage qualification, property insurance. AI-powered tenant scoring tools and dynamic pricing algorithms qualify."}]]}],["$","div","Healthcare",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Healthcare"}],["$","p",null,{"className":"text-sm text-muted","children":"Treatment recommendations, insurance coverage decisions, resource allocation. AI diagnostic tools and triage systems qualify."}]]}],["$","div","Legal services",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Legal services"}],["$","p",null,{"className":"text-sm text-muted","children":"Bail determinations, sentencing recommendations, case outcome predictions used to advise clients."}]]}],["$","div","Government services",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Government services"}],["$","p",null,{"className":"text-sm text-muted","children":"Benefits eligibility, licensing, permit approvals. AI systems used by government agencies to process applications."}]]}]]}]
16:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Key deadlines for SB 24-205 compliance"}]
17:["$","div",null,{"className":"space-y-4","children":[["$","div","February 1, 2026",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["February 1, 2026"," — ","Act takes effect"]}],["$","p",null,{"className":"text-sm text-muted","children":"The Colorado AI Act becomes law. All obligations begin to apply. Companies should already have compliance programs in progress."}]]}],["$","div","June 30, 2026",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["June 30, 2026"," — ","Initial impact assessments due"]}],["$","p",null,{"className":"text-sm text-muted","children":"Deployers must complete their first impact assessments for all high-risk AI systems in use. This is the hard compliance deadline most companies need to plan for."}]]}],["$","div","Ongoing",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":["Ongoing"," — ","Annual updates"]}],["$","p",null,{"className":"text-sm text-muted","children":"Impact assessments must be updated at least annually, or whenever significant modifications are made to a high-risk AI system."}]]}]]}]
18:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Obligations for AI developers"}]
19:["$","p",null,{"children":"If you build AI systems (including AI features in your SaaS product), the Colorado AI Act requires:"}]
1a:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"1. Reasonable care to protect against algorithmic discrimination"}]
1b:["$","p",null,{"children":"This is the Act's core requirement. You must use reasonable care to protect consumers from known or foreseeable risks of algorithmic discrimination. \"Reasonable care\" is assessed based on the totality of circumstances, including the size and complexity of the AI system, the nature and severity of potential harms, and the feasibility and cost of mitigation measures."}]
1c:["$","p",null,{"children":"Practically, this means testing your AI systems for bias across protected characteristics, documenting the training data and its known limitations, implementing safeguards against discriminatory outputs, and monitoring system behavior in production."}]
1d:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"2. Documentation and disclosure"}]
1e:["$","p",null,{"children":"Developers must make available to deployers and other developers:"}]
1f:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":"A general description of the AI system, including its intended uses and known limitations"}],["$","li",null,{"children":"Documentation of the training data, including known biases or gaps"}],["$","li",null,{"children":"The types of data the system processes and outputs it generates"}],["$","li",null,{"children":"Known risks of algorithmic discrimination and mitigation measures"}],["$","li",null,{"children":"How the system should be used, monitored, and maintained"}]]}]
20:["$","p",null,{"children":"This documentation enables deployers to conduct their own impact assessments and implement appropriate safeguards."}]
21:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"3. Public disclosure on your website"}]
22:["$","p",null,{"children":"Developers must publish a statement on their website that describes the types of high-risk AI systems they develop, how they manage known or foreseeable risks of algorithmic discrimination, and the nature of the high-risk AI systems they have developed."}]
23:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Obligations for AI deployers"}]
24:["$","p",null,{"children":"If your company uses high-risk AI systems (including AI features in SaaS products you subscribe to), you have deployer obligations:"}]
25:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"1. Risk management policy"}]
26:["$","p",null,{"children":"Deployers must implement a risk management policy and governance framework for high-risk AI systems. This includes designating personnel responsible for AI governance, establishing processes for identifying and mitigating discrimination risks, and training employees who interact with high-risk AI systems."}]
27:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"2. Impact assessments"}]
28:["$","p",null,{"children":"This is the most substantial deployer obligation. Before deploying a high-risk AI system — and at least annually thereafter — you must complete an impact assessment that includes:"}]
29:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":"The purpose, intended use cases, and deployment context of the AI system"}],["$","li",null,{"children":"An analysis of whether the system poses risks of algorithmic discrimination"}],["$","li",null,{"children":"The categories of data processed by the system"}],["$","li",null,{"children":"Metrics used to evaluate system performance and fairness"}],["$","li",null,{"children":"A description of the transparency measures provided to consumers"}],["$","li",null,{"children":"Post-deployment monitoring plans"}]]}]
2a:["$","p",null,{"children":"Impact assessments must be retained for at least three years and provided to the Colorado Attorney General upon request."}]
2b:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"3. Consumer transparency"}]
2c:["$","p",null,{"children":"Deployers must notify consumers before a high-risk AI system makes a consequential decision about them. The notice must include:"}]
2d:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":"That a high-risk AI system is being used to make or substantially assist in making a consequential decision"}],["$","li",null,{"children":"A description of the system and how it is used in the decision"}],["$","li",null,{"children":"Contact information for the deployer"}],["$","li",null,{"children":"A description of the consumer's right to opt out (where applicable) and appeal"}]]}]
2e:["$","h3",null,{"className":"text-xl font-bold tracking-tight text-foreground pt-2","children":"4. Consumer rights"}]
2f:["$","p",null,{"children":"When a high-risk AI system makes an adverse consequential decision, consumers have the right to:"}]
30:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":"Receive an explanation of the decision, including the principal factors and logic that led to the outcome"}],["$","li",null,{"children":"Appeal the decision and request human review"}],["$","li",null,{"children":"Correct inaccurate data that was used in the decision"}]]}]
31:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"The affirmative defense: NIST AI RMF alignment"}]
32:["$","p",null,{"children":"The Colorado AI Act provides an important affirmative defense. Developers and deployers that comply with a recognized AI risk management framework — specifically the NIST AI Risk Management Framework (AI RMF) or a substantially equivalent framework — can use that compliance as a defense against enforcement actions."}]
33:["$","p",null,{"children":"This is significant because it gives companies a clear path to compliance. If you implement the NIST AI RMF and can demonstrate adherence, you have a strong defense even if an algorithmic discrimination issue arises. Codepliant generates AI governance documentation aligned with the NIST AI RMF, giving you a starting point for this defense."}]
34:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Colorado AI Act vs. EU AI Act: key differences"}]
35:["$","div",null,{"className":"space-y-4","children":[["$","div","Scope",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Scope"}],["$","p",null,{"className":"text-sm text-muted","children":"The EU AI Act covers all AI systems with a risk-based classification. The Colorado Act focuses exclusively on high-risk AI systems that make consequential decisions."}]]}],["$","div","Primary concern",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Primary concern"}],["$","p",null,{"className":"text-sm text-muted","children":"The EU AI Act addresses safety, transparency, and fundamental rights broadly. The Colorado Act focuses specifically on algorithmic discrimination."}]]}],["$","div","Impact assessments",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Impact assessments"}],["$","p",null,{"className":"text-sm text-muted","children":"Both require impact assessments for high-risk systems. The Colorado Act requires annual updates and three-year retention. The EU Act has more detailed conformity assessment procedures."}]]}],["$","div","Enforcement",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Enforcement"}],["$","p",null,{"className":"text-sm text-muted","children":"The EU AI Act is enforced by national authorities with fines up to 7% of global turnover. The Colorado Act is enforced by the state Attorney General under existing consumer protection authority."}]]}],["$","div","Affirmative defense",{"className":"bg-surface rounded-xl p-5","children":[["$","h3",null,{"className":"font-semibold mb-1","children":"Affirmative defense"}],["$","p",null,{"className":"text-sm text-muted","children":"The Colorado Act provides an explicit affirmative defense for NIST AI RMF compliance. The EU AI Act has no equivalent safe harbor."}]]}]]}]
36:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Compliance action plan for SaaS companies"}]
37:["$","p",null,{"children":"With the June 30, 2026 impact assessment deadline approaching, here is what your team should do now:"}]
38:["$","ol",null,{"className":"list-decimal list-inside space-y-3 ml-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Identify your high-risk AI systems."}]," Review every AI feature in your product. Does it make or substantially influence decisions about employment, education, finance, housing, healthcare, or other consequential areas? If yes, it is a high-risk system under the Act. Run Codepliant to generate an AI inventory from your codebase."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Determine your role."}]," Are you a developer (building the AI), a deployer (using the AI), or both? Most SaaS companies that build AI features into their products are both."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Conduct impact assessments."}]," For each high-risk AI system, document its purpose, data inputs, decision outputs, discrimination risks, fairness metrics, and mitigation measures. This assessment must be completed by June 30, 2026."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Test for bias."}]," Evaluate your AI systems for differential treatment across protected characteristics. Use statistical fairness metrics appropriate to your use case (demographic parity, equalized odds, calibration)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Implement transparency notices."}]," Build consumer- facing disclosures that inform users when high-risk AI is used in decisions affecting them. Include appeal and opt-out mechanisms."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Establish governance."}]," Designate AI governance responsibility, create risk management policies, and train relevant staff. Use the NIST AI RMF as your framework to take advantage of the affirmative defense."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Generate documentation."}]," Use Codepliant to generate AI governance documentation aligned with NIST AI RMF. This documentation supports both compliance and the affirmative defense."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Plan for ongoing compliance."}]," Impact assessments must be updated annually and whenever significant system changes occur. Integrate Codepliant into your CI/CD pipeline to keep documentation current."]}]]}]
39:["$","h2",null,{"className":"text-2xl font-bold tracking-tight text-foreground pt-4","children":"Beyond Colorado: the US state AI regulation landscape"}]
3a:["$","p",null,{"children":"Colorado is the first state to enact comprehensive AI regulation, but it will not be the last. Several other states have introduced or are considering similar legislation:"}]
3b:["$","ul",null,{"className":"list-disc list-inside space-y-2 ml-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Illinois:"}]," The Illinois AI Video Interview Act already regulates AI in hiring. Broader AI legislation is under consideration."]}],["$","li",null,{"children":[["$","strong",null,{"children":"California:"}]," Multiple AI bills were introduced in 2024-2025, including proposals for algorithmic impact assessments and AI transparency requirements."]}],["$","li",null,{"children":[["$","strong",null,{"children":"New York City:"}]," Local Law 144 regulates automated employment decision tools, requiring annual bias audits."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Connecticut:"}]," Enacted an AI governance framework in 2024 with disclosure and assessment requirements for state agencies."]}]]}]
3c:["$","p",null,{"children":"The trend is clear: AI regulation is expanding across the United States. Building compliance infrastructure now — impact assessment frameworks, transparency systems, governance processes — prepares you for the regulations that follow Colorado."}]
3d:["$","section",null,{"className":"bg-surface rounded-2xl p-8 text-center mt-16 mb-16","children":[["$","h2",null,{"className":"text-xl font-bold mb-3","children":"Prepare for the Colorado AI Act deadline"}],["$","p",null,{"className":"text-muted text-sm mb-6","children":"Scan your codebase to generate AI governance documentation aligned with NIST AI RMF. Free, open source, no account required."}],["$","div",null,{"className":"bg-code-bg text-code-fg px-6 py-3 rounded-xl font-mono text-sm inline-block","children":"npx codepliant go"}]]}]
