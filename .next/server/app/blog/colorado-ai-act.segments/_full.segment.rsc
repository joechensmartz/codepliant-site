44:[["$","title","0",{"children":"Colorado AI Act: What SaaS Companies Need to Know | Codepliant"}],["$","meta","1",{"name":"description","content":"Guide to the Colorado AI Act (SB 24-205) for SaaS companies. Covers the February 1, 2026 effective date, high-risk AI system requirements, algorithmic discrimination prevention, impact assessments, and compliance steps."}],["$","meta","2",{"name":"robots","content":"index, follow"}],["$","meta","3",{"name":"googlebot","content":"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}],["$","link","4",{"rel":"canonical","href":"https://codepliant.dev/blog/colorado-ai-act"}],["$","meta","5",{"property":"og:title","content":"Colorado AI Act: What SaaS Companies Need to Know"}],["$","meta","6",{"property":"og:description","content":"The Colorado AI Act takes effect February 1, 2026 with a compliance deadline of June 30, 2026. Learn what SaaS companies must do to comply with SB 24-205."}],["$","meta","7",{"property":"og:url","content":"https://codepliant.dev/blog/colorado-ai-act"}],["$","meta","8",{"property":"og:image","content":"https://codepliant.dev/og-image.png"}],["$","meta","9",{"property":"og:image:width","content":"1200"}],["$","meta","10",{"property":"og:image:height","content":"630"}],["$","meta","11",{"property":"og:type","content":"article"}],["$","meta","12",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","13",{"name":"twitter:title","content":"Colorado AI Act: What SaaS Companies Need to Know"}],["$","meta","14",{"name":"twitter:description","content":"SB 24-205 compliance guide for SaaS companies. Deadlines, requirements, impact assessments, and practical steps."}],["$","meta","15",{"name":"twitter:image","content":"https://codepliant.dev/og-image.png"}]]
