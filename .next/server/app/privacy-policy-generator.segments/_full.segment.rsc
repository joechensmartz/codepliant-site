f:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Code scanning vs. questionnaires"}],["$","div",null,{"className":"space-y-6 text-base text-muted leading-relaxed","children":[["$","p",null,{"children":"Traditional privacy policy generators rely on you knowing every data practice in your application. Do you use cookies? Which analytics provider? What personal data do you store? Miss one checkbox, and your privacy policy is inaccurate."}],["$","p",null,{"children":"Codepliant takes a different approach. It performs static analysis on your source code, scanning for patterns that indicate data collection, storage, and processing. It detects ORM schemas (Prisma, Drizzle, Mongoose, TypeORM, Sequelize, Django, SQLAlchemy), authentication flows, analytics SDKs, payment integrations, and more."}],["$","p",null,{"children":"The result is a privacy policy generated from evidence, not guesswork. Across 100 real-world GitHub repositories, Codepliant achieves 97.8% detection precision."}]]}]]}]
10:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"What Codepliant detects in your code"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-4","children":[["$","div","Cookies & session management",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Cookies & session management"}],["$","div","Google Analytics, Mixpanel, Segment",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Google Analytics, Mixpanel, Segment"}],["$","div","Prisma, Drizzle, Mongoose schemas",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Prisma, Drizzle, Mongoose schemas"}],["$","div","OAuth, JWT, SSO authentication",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"OAuth, JWT, SSO authentication"}],["$","div","Stripe, PayPal payment processing",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Stripe, PayPal payment processing"}],["$","div","Email collection & newsletters",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Email collection & newsletters"}],["$","div","File uploads & storage",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"File uploads & storage"}],["$","div","Geolocation & IP tracking",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Geolocation & IP tracking"}],["$","div","AI/ML model usage (OpenAI, etc.)",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"AI/ML model usage (OpenAI, etc.)"}],["$","div","Third-party API integrations",{"className":"bg-surface rounded-xl px-4 py-3 text-sm","children":"Third-party API integrations"}]]}]]}]
11:["$","section",null,{"className":"mb-16","children":[["$","h2",null,{"className":"text-2xl font-bold tracking-tight mb-6","children":"Example output preview"}],["$","div",null,{"className":"bg-code-bg text-code-fg rounded-2xl p-6 font-mono text-sm leading-relaxed overflow-x-auto","children":["$","pre",null,{"children":"# Privacy Policy\n\nLast updated: March 15, 2026\n\n## Data We Collect\n\nBased on our analysis of this application's source code,\nthe following data collection practices were identified:\n\n### Personal Information\n- Email addresses (via authentication flow)\n- User profiles (stored in PostgreSQL via Prisma)\n- Payment information (processed by Stripe)\n\n### Automatically Collected Data\n- Cookies (session management, 3 cookies detected)\n- Analytics data (Google Analytics, Mixpanel)\n- IP addresses (server logs)\n- Device information (user-agent parsing)\n\n### Third-Party Services\n- Stripe (payment processing)\n- Google Analytics (usage analytics)\n- Mixpanel (event tracking)\n- AWS S3 (file storage)\n- OpenAI API (AI-powered features)\n\n## Your Rights Under GDPR\n..."}]}]]}]
